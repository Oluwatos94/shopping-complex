# =============================================================================
# Jiidaa SEP-24 Anchor — testnet env.
# Adapted from anchor-platform/quick-run/dev.env. The SEP-10 signing seed is injected at runtime by
# ap_start.sh (see docker-compose.yaml `SECRET_SEP10_SIGNING_SEED`), not stored here.
# =============================================================================

# ----- Stellar network -------------------------------------------------------
STELLAR_NETWORK_TYPE=rpc
STELLAR_NETWORK_RPC_URL=https://soroban-testnet.stellar.org

# ----- Secrets / auth (testnet only) -----------------------------------------
SECRET_DATA_USERNAME=postgres
SECRET_DATA_PASSWORD=password

SECRET_SEP10_JWT_SECRET=secret_sep10_secret_secret_sep10_secret
SECRET_SEP24_INTERACTIVE_URL_JWT_SECRET=secret_sep24_interactive_url_jwt_secret
SECRET_SEP24_MORE_INFO_URL_JWT_SECRET=secret_sep24_more_info_url_jwt_secret
SECRET_SEP6_MORE_INFO_URL_JWT_SECRET=secret_sep6_more_info_url_jwt_secret

# ----- Logging ---------------------------------------------------------------
APP_LOGGING_STELLAR_LEVEL=DEBUG
APP_LOGGING_REQUEST_LOGGER_ENABLED=true

LANGUAGES=en

# ----- Event processing ------------------------------------------------------
EVENTS_ENABLED=true
EVENTS_QUEUE_TYPE=kafka
EVENTS_QUEUE_KAFKA_BOOTSTRAP_SERVER=kafka:29092
EVENT_PROCESSOR_CALLBACK_API_REQUEST_ENABLED=true

# ----- Internal API endpoints ------------------------------------------------
CALLBACK_API_BASE_URL=http://reference-server:8091/
PLATFORM_API_BASE_URL=http://platform:8085

# ----- Database --------------------------------------------------------------
DATA_TYPE=postgres
DATA_SERVER=db:5432
DATA_DATABASE=postgres
DATA_SCHEMA=anchor-platform
DATA_FLYWAY_ENABLED=true

# ----- Assets ----------------------------------------------------------------
ASSETS_TYPE=file
ASSETS_VALUE=/config/assets.yaml

# =============================================================================
# SEP toggles
# =============================================================================

# SEP-1: Stellar Info File (stellar.toml)
SEP1_ENABLED=true
SEP1_TOML_TYPE=file
SEP1_TOML_VALUE=/config/stellar.localhost.toml

# SEP-6: programmatic deposit/withdraw. Kept ON because 4.4.0 gates the SEP-24
# controller's exchangeAmountsCalculator bean on @OnAllSepsEnabled(sep6, sep24, sep31).
SEP6_ENABLED=true
SEP6_MORE_INFO_URL_BASE_URL=http://localhost:8091/sep6/transaction/more_info

# SEP-10: Stellar Web Authentication — how our custodial vendor wallets authenticate.
# WEB_AUTH_DOMAIN is the bare host (no port): the soneso PHP client validates the
# challenge's web_auth_domain against parse_url(authEndpoint)['host'], which strips the
# port. HOME_DOMAINS keeps the :8080 form so the SEP-1 toml/SEP-24 URLs stay consistent.
SEP10_ENABLED=true
SEP10_WEB_AUTH_DOMAIN=localhost
SEP10_HOME_DOMAINS=localhost:8080,*.stellar.org

# SEP-12: KYC/Customer info (reference server collects minimal info in the interactive UI).
SEP12_ENABLED=true

# SEP-24: interactive deposit/withdraw — the deliverable. INTERACTIVE_URL must point at the
# sep24-reference-ui SPA (:3000), which renders the real deposit form and drives it to
# completion against the reference server (:8091). Pointing it at the reference server's
# /sep24/interactive returns only a stub ("…interactive flow starts here"), so the form
# never appears. The UI reads the ?token= the anchor appends. more_info stays on :8091.
SEP24_ENABLED=true
SEP24_INTERACTIVE_URL_BASE_URL=http://localhost:3000
SEP24_MORE_INFO_URL_BASE_URL=http://localhost:8091/sep24/transaction/more_info

# SEP-31 / SEP-38: kept ON to satisfy the SEP-24 bean wiring above (and SEP-38 backs
# SEP-24 exchange-amount calculation). Not used by Jiidaa directly; the reference
# server services their callbacks. Only NGNC/SEP-24 matters to us.
SEP31_ENABLED=true
SEP38_ENABLED=true

# SEP-45: contract-account web auth — DISABLED. Our wallets are classic (G...) accounts,
# which authenticate via SEP-10. SEP-45 only applies to contract (C...) accounts and would
# pull in a required web_auth_verify Soroban contract for no benefit here.
SEP45_ENABLED=false
